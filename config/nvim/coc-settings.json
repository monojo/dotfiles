{
    "languageserver": {
        "ccls": {
            "command": "ccls",
            "filetypes": [
                "c",
                "cpp",
                "cuda",
                "objc",
                "objcpp"
            ],
            "rootPatterns": [
                ".ccls",
                "compile_commands.json",
                ".vim/",
                ".git/",
                ".hg/"
            ],
            "initializationOptions": {
                "cache": {
                    "directory": "/tmp/ccls-cache"
                },
                "highlight": {
                    "lsRanges": true
                }
            }
        }
    },
    "diagnostic.virtualText": true,
    "coc.preferences.jumpCommand": "edit",
    /*"codeLens.enable": true */
}
