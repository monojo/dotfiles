[submodule "zsh/prezto"]
	path = zsh/prezto
	url = https://github.com/sorin-ionescu/prezto.git
  ignore = dirty
[submodule "bin/vim"]
	path = bin/vim
	url = https://github.com/vim/vim.git
[submodule "bin/imgur_screenshot"]
	path = bin/imgur_screenshot
	url = https://github.com/monojo/imgur_screenshot.git
[submodule "bin/tpm"]
	path = bin/tpm
	url = https://github.com/tmux-plugins/tpm.git
[submodule "i3"]
	path = i3
	url = https://github.com/monojo/i3.git
