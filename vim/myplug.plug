"======Appearance=====
Plug 'vim-airline/vim-airline'
Plug 'vim-airline/vim-airline-themes'
"ultimate color collection
Plug 'flazz/vim-colorschemes'
"======Finder======
Plug 'junegunn/fzf', {'dir': '~/.fzf', 'do': './install --all'}
Plug 'junegunn/fzf.vim'
"======Navigation======
"ctags overview on the go
Plug 'majutsushi/tagbar'
"======Version Control======
"gv dependency
Plug 'tpope/vim-fugitive'
Plug 'junegunn/gv.vim'
"======Snippets======
Plug 'SirVer/ultisnips'
Plug 'honza/vim-snippets'
"======Extra Info======
"Show register content, press "
Plug 'junegunn/vim-peekaboo'
"Highlight multiple words
Plug 't9md/vim-quickhl'
"======Motion======
Plug 'easymotion/vim-easymotion'
"======Language Server Protocol Client======
" A new extension framework including LSP client support
Plug 'neoclide/coc.nvim', {'branch': 'release'}
" lsp based c/cxx syntax hightlight
Plug 'jackguo380/vim-lsp-cxx-highlight'
"======MISC======
"Better comment
Plug 'scrooloose/nerdcommenter'
"Move between tmux pane and vim window
Plug 'christoomey/vim-tmux-navigator'
"Use . to repeat plugin map
Plug 'tpope/vim-repeat'
"Display marks on left
Plug 'kshenoy/vim-signature'

